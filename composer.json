{
    "name": "milpa/core",
    "description": "Milpa Framework — core contracts and primitives. Framework-agnostic: no ORM, no HTTP client, no host-application coupling (ADR-001).",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.3",
        "psr/container": "^2.0",
        "symfony/event-dispatcher-contracts": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Milpa\\app\\Exceptions\\": "src/Exceptions/",
            "Milpa\\app\\ValueObjects\\": "src/ValueObjects/",
            "Milpa\\app\\DTO\\": "src/DTO/",
            "Milpa\\app\\Enums\\": "src/Enums/",
            "Milpa\\app\\Attributes\\": "src/Attributes/",
            "Milpa\\app\\Events\\": "src/Events/",
            "Milpa\\app\\Services\\": "src/Services/",
            "Milpa\\app\\Interfaces\\": "src/Interfaces/",
            "Milpa\\app\\Support\\": "src/Support/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Milpa\\Tests\\": "tests/",
            "Milpa\\Docs\\": "tools/gen-docs/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpdoc-parser": "^2.3"
    }
}
